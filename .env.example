# Bu dosya örnek şablondur, gerçek anahtar içermez.
# Kopyala: cp .env.example .env.local  ve anahtarını .env.local içine yaz.
OPENROUTER_API_KEY=
# MODEL=moonshotai/kimi-k3

# Araca giriş şifresi (zorunlu — tanımlı değilse araç kapalı kalır)
APP_PASSWORD=

# Oturum çerezini imzalayan gizli anahtar (zorunlu, şifreyle ilgisiz).
# Üret:  openssl rand -hex 32
SESSION_SECRET=

# Paylaşım linklerinde kullanılacak asıl adres (Vercel önizleme adreslerini önlemek için)
NEXT_PUBLIC_SITE_URL=

# "Var olan proje" (git repo) modu — varsayılan KAPALI.
# Bu mod klonlanan reponun KENDİ KODUNU çalıştırır (install + dev sunucusu),
# o yüzden bilinçli olarak açılması gerekir. Sadece yerelde kullan:
#   REPO_MODE_ENABLED=1
REPO_MODE_ENABLED=
