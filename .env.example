# Bu dosya örnek şablondur, gerçek anahtar içermez.
# Kopyala: cp .env.example .env.local  ve anahtarını .env.local içine yaz.
OPENROUTER_API_KEY=
# MODEL=moonshotai/kimi-k3

# Supabase — ikisi de gerekli, yoksa veritabanı kapalı çalışır (proje kaydedilmez).
# Adres: panel → Project Settings → Data API → Project URL
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Araca giriş şifresi. BOŞ bırakılırsa şifre kapısı DEVRE DIŞI kalır ve araç
# doğrudan açılır (yerel, tek kullanıcılı kullanım için).
# İnternete açık bir yere kurarken MUTLAKA doldur.
APP_PASSWORD=

# Oturum çerezini imzalayan gizli anahtar (zorunlu, şifreyle ilgisiz).
# Üret:  openssl rand -hex 32
SESSION_SECRET=

# Paylaşım linklerinde kullanılacak asıl adres (Vercel önizleme adreslerini önlemek için)
NEXT_PUBLIC_SITE_URL=

# "Var olan proje" (git repo) modu — varsayılan KAPALI.
# Bu mod klonlanan reponun KENDİ KODUNU çalıştırır (install + dev sunucusu),
# o yüzden bilinçli olarak açılması gerekir. Sadece yerelde kullan:
#   REPO_MODE_ENABLED=1
REPO_MODE_ENABLED=

# Repo modundaki "Commit & Push" için erişim token'ı. GitHub: Settings →
# Developer settings → Personal access tokens → Fine-grained; ilgili repolara
# "Contents: Read and write" yetkisi ver. Boşsa push devre dışı kalır
# (düzenleme/önizleme etkilenmez).
GIT_PUSH_TOKEN=
# GitHub dışındaki host'larda token'ın kullanıcı adı (GitLab için: oauth2).
# GIT_PUSH_USER=x-access-token
